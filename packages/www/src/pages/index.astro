---
import RootLayout from "../components/RootLayout.astro";
import Landing from "../components/Landing.astro";
import { DEFAULT_LOCALE, makeTranslator } from "../i18n/translations";

const locale = DEFAULT_LOCALE;
const t = makeTranslator(locale);

const title = `RecipeSage - ${t("pages.welcome.title")}`;
const description = t("pages.welcome.subtitle");
---

<RootLayout
  locale={locale}
  t={t}
  title={title}
  description={description}
  redirectLoggedIn
>
  <Landing t={t} locale={locale} />
</RootLayout>
