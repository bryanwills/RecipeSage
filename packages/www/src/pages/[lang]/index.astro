---
import RootLayout from "../../components/RootLayout.astro";
import Landing from "../../components/Landing.astro";
import {
  DEFAULT_LOCALE,
  SUPPORTED_LOCALES,
  makeTranslator,
} from "../../i18n/translations";

export function getStaticPaths() {
  return SUPPORTED_LOCALES.filter((l) => l !== DEFAULT_LOCALE).map((l) => ({
    params: { lang: l },
  }));
}

const { lang } = Astro.params;
if (!lang) throw new Error("lang param missing");
const t = makeTranslator(lang);

const title = `RecipeSage - ${t("pages.welcome.title")}`;
const description = t("pages.welcome.subtitle");
---

<RootLayout
  locale={lang}
  t={t}
  title={title}
  description={description}
  redirectLoggedIn
>
  <Landing t={t} locale={lang} />
</RootLayout>
