---
import RootLayout from "../../components/RootLayout.astro";
import PricingContent from "../../components/Pricing.astro";
import {
  DEFAULT_LOCALE,
  SUPPORTED_LOCALES,
  makeTranslator,
} from "../../i18n/translations";

export function getStaticPaths() {
  return SUPPORTED_LOCALES.filter((l) => l !== DEFAULT_LOCALE).map((l) => ({
    params: { lang: l },
  }));
}

const { lang } = Astro.params;
if (!lang) throw new Error("lang param missing");
const t = makeTranslator(lang);

const title = t("pages.pricing.tabTitle");
const description = t("pages.pricing.subtitle");
---

<RootLayout locale={lang} t={t} title={title} description={description}>
  <PricingContent t={t} />
</RootLayout>
