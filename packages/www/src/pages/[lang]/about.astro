---
import RootLayout from "../../components/RootLayout.astro";
import AboutContent from "../../components/About.astro";
import {
  DEFAULT_LOCALE,
  WWW_SUPPORTED_LOCALES,
  localePath,
  makeTranslator,
} from "../../i18n/translations";

export function getStaticPaths() {
  return WWW_SUPPORTED_LOCALES.filter((l) => l !== DEFAULT_LOCALE).map((l) => ({
    params: { lang: l },
  }));
}

const { lang } = Astro.params;
if (!lang) throw new Error("lang param missing");
const t = makeTranslator(lang);

const title = `${t("pages.about.title")} - RecipeSage`;
const description = t("pages.about.metaDescription");

const breadcrumbs = [
  { name: "RecipeSage", url: `/${lang}/` },
  { name: t("pages.about.title"), url: localePath(lang, "/about") },
];
---

<RootLayout
  locale={lang}
  t={t}
  title={title}
  description={description}
  breadcrumbs={breadcrumbs}
>
  <AboutContent t={t} />
</RootLayout>
