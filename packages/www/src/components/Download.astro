---
import { Picture } from "astro:assets";
import type { Translator } from "../i18n/translations";

const heroBg =
  "https://static.recipesage.com/assets/art/chicken-salad-2025-05-03.jpg";

interface Props {
  t: Translator;
}

const { t } = Astro.props;

const bookmarklet =
  "javascript:(function(){location.href='https://recipesage.com/app/edit-recipe/new?autofill-url='+encodeURIComponent(location.href);})();";
---

<section class="download-hero">
  <Picture
    src={heroBg}
    widths={[640, 1280, 1920]}
    sizes="100vw"
    formats={["avif", "webp"]}
    fallbackFormat="jpg"
    alt=""
    class="download-hero-bg"
    loading="eager"
    decoding="async"
    inferSize
  />
  <div class="download-hero-inner">
    <h1>{t("pages.downloadAndInstall.title")}</h1>
    <p class="lead">{t("pages.downloadAndInstall.subtitle")}</p>
  </div>
</section>

<article class="download-content">
  <section class="platform">
    <div class="platform-header">
      <span class="platform-icon" aria-hidden="true">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="28"
          height="28"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect width="14" height="20" x="5" y="2" rx="2" ry="2"></rect>
          <path d="M12 18h.01"></path>
        </svg>
      </span>
      <h2>{t("pages.downloadAndInstall.android.title")}</h2>
    </div>
    <p class="instruction-header">
      {t("pages.downloadAndInstall.android.instructionHeader")}
    </p>
    <ol>
      <li>{t("pages.downloadAndInstall.android.step.1")}</li>
      <li>
        {t("pages.downloadAndInstall.android.step.2")}
        <span class="icon-hint" aria-label={t("pages.downloadAndInstall.icon.menuDots")}>⋮</span>
      </li>
      <li>{t("pages.downloadAndInstall.android.step.3")}</li>
    </ol>
  </section>

  <section class="platform">
    <div class="platform-header">
      <span class="platform-icon" aria-hidden="true">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="28"
          height="28"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect width="14" height="20" x="5" y="2" rx="2" ry="2"></rect>
          <path d="M12 18h.01"></path>
        </svg>
      </span>
      <h2>{t("pages.downloadAndInstall.ios.title")}</h2>
    </div>
    <p class="instruction-header">
      {t("pages.downloadAndInstall.ios.instructionHeader")}
    </p>
    <ol>
      <li>{t("pages.downloadAndInstall.ios.step.1")}</li>
      <li>
        {t("pages.downloadAndInstall.ios.step.2")}
        <span class="icon-hint" aria-label={t("pages.downloadAndInstall.icon.share")}>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="16 6 12 2 8 6"></polyline>
            <line x1="12" x2="12" y1="2" y2="15"></line>
          </svg>
        </span>
      </li>
      <li>{t("pages.downloadAndInstall.ios.step.3")}</li>
    </ol>
  </section>

  <section class="platform">
    <div class="platform-header">
      <span class="platform-icon" aria-hidden="true">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="28"
          height="28"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path
            d="M20 16V7a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v9m16 0H4m16 0 1.28 2.55a1 1 0 0 1-.9 1.45H3.62a1 1 0 0 1-.9-1.45L4 16"
          ></path>
        </svg>
      </span>
      <h2>{t("pages.downloadAndInstall.desktop.title")}</h2>
    </div>
    <p class="instruction-header">
      {t("pages.downloadAndInstall.desktop.instructionHeader")}
    </p>
    <ol>
      <li>{t("pages.downloadAndInstall.desktop.step.1")}</li>
      <li>
        {t("pages.downloadAndInstall.desktop.step.2")}
        <span class="icon-hint" aria-label={t("pages.downloadAndInstall.icon.menuDots")}>⋮</span>
      </li>
      <li>{t("pages.downloadAndInstall.desktop.step.3")}</li>
    </ol>
  </section>

  <section class="other">
    <h2>{t("pages.downloadAndInstall.other")}</h2>

    <div class="other-card">
      <h3>{t("pages.downloadAndInstall.extension")}</h3>
      <p>{t("pages.downloadAndInstall.extension.description")}</p>
      <p class="store-links">
        <a
          class="store-link"
          href="https://addons.mozilla.org/en-US/firefox/addon/recipesage/"
          target="_blank"
          rel="noopener">{t("pages.downloadAndInstall.extension.installFirefox")}</a
        >
        <a
          class="store-link"
          href="https://chrome.google.com/webstore/detail/oepplnnfceidfaaacjpdpobnjkcpgcpo"
          target="_blank"
          rel="noopener">{t("pages.downloadAndInstall.extension.installChrome")}</a
        >
      </p>
    </div>

    <div class="other-card">
      <h3>{t("pages.downloadAndInstall.bookmark")}</h3>
      <p>{t("pages.downloadAndInstall.bookmark.description")}</p>
      <p>
        <a
          class="bookmarklet"
          href={bookmarklet}
          onclick="return false"
          title="Autoclip to RecipeSage"
          >{t("pages.downloadAndInstall.bookmark.instructions")}</a
        >
        {t("pages.downloadAndInstall.bookmark.usage")}
      </p>
    </div>
  </section>
</article>

<style>
  .download-hero {
    position: relative;
    isolation: isolate;
    color: var(--hero-text);
    overflow: hidden;
    padding: 140px 24px 60px;
  }

  .download-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: -1;
  }

  @media (max-width: 800px) {
    .download-hero {
      padding: 50px 24px 50px;
    }
  }

  .download-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0.7) 0%, transparent 180px),
      var(--hero-overlay);
  }

  .download-hero-inner {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
  }

  .download-hero h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin: 0 0 12px;
    font-weight: 600;
  }

  .lead {
    font-size: 1.15rem;
    margin: 0;
    opacity: 0.95;
  }

  .download-content {
    max-width: 760px;
    margin: 0 auto;
    padding: 40px 24px 0;
    line-height: 1.65;
  }

  .platform {
    background: var(--surface);
    border-radius: 12px;
    padding: 24px;
    margin-bottom: 20px;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
  }

  .platform-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .platform-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--text);
    flex-shrink: 0;
  }

  .platform h2 {
    margin: 0;
    font-size: 1.3rem;
  }

  .instruction-header {
    color: var(--text-muted);
    margin: 0 0 12px;
  }

  .platform ol {
    margin: 0;
    padding-left: 20px;
    color: var(--text);
  }

  .platform ol li {
    margin-bottom: 8px;
  }

  .icon-hint {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 4px;
    background: rgba(0, 0, 0, 0.07);
    margin-left: 4px;
    font-weight: 600;
  }

  @media (prefers-color-scheme: dark) {
    .icon-hint {
      background: rgba(255, 255, 255, 0.1);
    }
  }

  .other {
    margin-top: 40px;
  }

  .other > h2 {
    font-size: 1.4rem;
    margin: 0 0 16px;
  }

  .other-card {
    background: var(--surface);
    border-radius: 12px;
    padding: 20px 24px;
    margin-bottom: 16px;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
  }

  .other-card h3 {
    margin: 0 0 8px;
    font-size: 1.1rem;
  }

  .other-card p {
    color: var(--text-muted);
    margin: 0 0 8px;
  }

  .store-links {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .store-link {
    color: var(--accent-text);
    text-shadow: none;
  }

  .bookmarklet {
    color: var(--accent-text);
    cursor: grab;
  }
</style>
