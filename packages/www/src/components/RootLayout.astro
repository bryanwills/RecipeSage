---
import Nav from "./Nav.astro";
import {
  DEFAULT_LOCALE,
  SUPPORTED_LOCALES,
  localePath,
  makeTranslator,
  toBcp47,
  type Translator,
} from "../i18n/translations";

interface Props {
  locale?: string;
  t?: Translator;
  title?: string;
  description?: string;
  image?: string;
  ogType?: string;
  noindex?: boolean;
  structuredData?: unknown;
  redirectLoggedIn?: boolean;
}

const {
  locale = DEFAULT_LOCALE,
  t = makeTranslator(DEFAULT_LOCALE),
  title = "RecipeSage - Free Recipe Keeper, Meal Planner, and Shopping List",
  description = "Save, organize, and share recipes with RecipeSage. Auto-import recipes from any website, plan meals, generate smart shopping lists, and sync across Web, iOS, and Android. Free and open source.",
  image = "https://recipesage.com/assets/recipesage-black-trimmed.png",
  ogType = "website",
  noindex = false,
  structuredData = null,
  redirectLoggedIn = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const homeHref = locale === DEFAULT_LOCALE ? "/" : `/${locale}/`;

const stripLocalePrefix = (pathname: string): string => {
  for (const loc of SUPPORTED_LOCALES) {
    if (loc === DEFAULT_LOCALE) continue;
    if (pathname === `/${loc}` || pathname === `/${loc}/`) return "/";
    if (pathname.startsWith(`/${loc}/`)) return pathname.slice(loc.length + 1);
  }
  return pathname;
};

const basePath = stripLocalePrefix(Astro.url.pathname);

const alternateUrlFor = (loc: string) => {
  const path =
    loc === DEFAULT_LOCALE ? basePath : `/${loc}${basePath === "/" ? "/" : basePath}`;
  return new URL(path, Astro.site).toString();
};

const localeHomeURL = new URL(homeHref, Astro.site).toString();

const htmlLang = toBcp47(locale);
const aboutHref = localePath(locale, "/about");

const defaultStructuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://recipesage.com/#organization",
      "name": "RecipeSage",
      "url": "https://recipesage.com/",
      "logo": {
        "@type": "ImageObject",
        "url": "https://recipesage.com/assets/recipesage-black-trimmed.png",
      },
      "sameAs": ["https://github.com/julianpoy/recipesage"],
    },
    {
      "@type": "WebSite",
      "@id": `${localeHomeURL}#website`,
      "url": localeHomeURL,
      "name": "RecipeSage",
      "publisher": { "@id": "https://recipesage.com/#organization" },
      "inLanguage": htmlLang,
    },
    {
      "@type": "SoftwareApplication",
      "name": "RecipeSage",
      "applicationCategory": "LifestyleApplication",
      "operatingSystem": ["Web", "iOS", "Android"],
      "url": localeHomeURL,
      "inLanguage": htmlLang,
      "description":
        "A free recipe keeper, meal planner, and shopping list organizer for Web, iOS, and Android. Auto-import recipes from any website, plan meals, and generate smart shopping lists.",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD",
      },
    },
  ],
};

const finalStructuredData = structuredData ?? defaultStructuredData;
---

<!doctype html>
<html lang={htmlLang} dir="ltr">
  <head>
    <script is:inline define:vars={{ redirectLoggedIn }}>
      (function () {
        if (location.hash.startsWith("#/")) {
          location.replace("/app" + location.hash.slice(1) + location.search);
          return;
        }
        if (!redirectLoggedIn) return;
        let token = null;
        try {
          token = localStorage.getItem("token");
        } catch {
          token = null;
        }
        if (token) location.replace("/app/");
      })();
    </script>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta
      name="viewport"
      content="viewport-fit=cover, width=device-width, initial-scale=1.0"
    />
    <meta name="format-detection" content="telephone=no" />
    <meta name="msapplication-tap-highlight" content="no" />

    <meta name="description" content={description} />
    <meta name="author" content="RecipeSage" />
    {
      noindex ? (
        <meta name="robots" content="noindex, nofollow" />
      ) : (
        <meta name="robots" content="index, follow, max-image-preview:large" />
      )
    }

    <link rel="canonical" href={canonicalURL} />
    {
      SUPPORTED_LOCALES.map((loc) => (
        <link
          rel="alternate"
          hreflang={toBcp47(loc)}
          href={alternateUrlFor(loc)}
        />
      ))
    }
    <link
      rel="alternate"
      hreflang="x-default"
      href={alternateUrlFor(DEFAULT_LOCALE)}
    />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="RecipeSage" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={image} />
    <meta property="og:image:alt" content="RecipeSage logo" />
    <meta property="og:locale" content={toBcp47(locale).replace("-", "_")} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <meta name="twitter:image:alt" content="RecipeSage logo" />

    <link rel="preconnect" href="https://static.recipesage.com" crossorigin />
    <link rel="dns-prefetch" href="https://static.recipesage.com" />

    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/app/assets/icon/favicon-32x32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/app/assets/icon/favicon-16x16.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/app/assets/icon/apple-touch-icon.png"
    />
    <link rel="shortcut icon" href="/app/assets/icon/favicon.ico" />
    <meta name="msapplication-TileColor" content="#353b48" />

    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#353b48" />
    <meta name="color-scheme" content="light dark" />

    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black" />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(finalStructuredData)}
    />

    <script is:inline>
      const _paq = window._paq = window._paq || [];
      _paq.push(['trackPageView']);
      _paq.push(['enableLinkTracking']);
      (function() {
        const u="https://a.recipesage.com/";
        _paq.push(['setTrackerUrl', u+'matomo.php']);
        _paq.push(['setSiteId', '1']);
        const d=document, g=d.createElement('script'), s=d.getElementsByTagName('script')[0];
        g.async=true; g.src=u+'matomo.js'; s.parentNode.insertBefore(g,s);
      })();
    </script>
    <noscript>
      <img
        referrerpolicy="no-referrer-when-downgrade"
        src={`https://a.recipesage.com/matomo.php?idsite=1&rec=1&action_name=${encodeURIComponent(title)}`}
        style="border:0"
        alt=""
      />
    </noscript>

    <script is:inline>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker
            .register("/service-worker.js", {
              scope: "/",
              updateViaCache: "none",
            })
            .catch((err) => console.error("SW registration failed", err));
        });
      }
    </script>

    <style is:global>
      :root {
        --bg: #fafafa;
        --surface: #ffffff;
        --text: #1b1d1f;
        --text-muted: #555;
        --hero-overlay: rgba(0, 0, 0, 0.55);
        --btn-border: rgba(255, 255, 255, 0.7);
        --btn-primary-bg: #5e8b56;
        --btn-primary-text: #ffffff;
        --hero-text: #ffffff;
        --footer-bg: #2c313b;
        --footer-text: #cfd6e4;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #14181f;
          --surface: #1c2129;
          --text: #e7eaef;
          --text-muted: #a8b0bd;
          --hero-overlay: rgba(0, 0, 0, 0.7);
          --footer-bg: #0f1218;
          --footer-text: #a8b0bd;
        }
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
      }

      body {
        font-family:
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          Roboto,
          "Helvetica Neue",
          Arial,
          sans-serif;
        color: var(--text);
        background: var(--bg);
        line-height: 1.5;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }

      main.site-main {
        flex: 1 0 auto;
      }

      a {
        color: inherit;
      }

      header.site-header {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        z-index: 10;
      }

      @media (max-width: 800px) {
        header.site-header {
          position: static;
          background: var(--footer-bg);
        }
      }
    </style>
  </head>
  <body>
    <noscript>
      <h1>You don't have javascript enabled.</h1>
      <p>This application requires javascript.</p>
    </noscript>

    <header class="site-header">
      <Nav t={t} locale={locale} homeHref={homeHref} />
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <a href="/app/legal">{t("pages.app.nav.legal")}</a>
        <a href={aboutHref}>{t("pages.app.nav.about")}</a>
        <a
          href="https://github.com/julianpoy/recipesage"
          target="_blank"
          rel="noopener">{t("pages.app.nav.github")}</a
        >
        <a href="https://docs.recipesage.com" target="_blank" rel="noopener"
          >{t("pages.app.nav.docs")}</a
        >
      </div>
    </footer>

    <style>
      .site-footer {
        background: var(--footer-bg);
        color: var(--footer-text);
        padding: 32px 24px;
        margin-top: 60px;
      }

      .footer-inner {
        max-width: 1400px;
        margin: 0 auto;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 12px 24px;
        font-size: 0.9rem;
      }

      .footer-inner a {
        color: inherit;
        text-decoration: none;
        opacity: 0.8;
      }

      .footer-inner a:hover {
        opacity: 1;
      }
    </style>
  </body>
</html>
