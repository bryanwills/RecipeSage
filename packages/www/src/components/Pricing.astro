---
import type { Translator } from "../i18n/translations";

interface Props {
  t: Translator;
}

const { t } = Astro.props;
---

<section class="pricing-hero">
  <div class="pricing-hero-inner">
    <h1>{t("pages.pricing.title")}</h1>
    <p class="lead">{t("pages.pricing.subtitle")}</p>
  </div>
</section>

<section class="pricing-content">
  <section class="why">
    <p class="lede">{t("pages.contribute.mission")}</p>
    <p>{t("pages.pricing.intro.alwaysFree")}</p>
    <p>{t("pages.pricing.intro.openSource")}</p>
  </section>

  <section class="support">
    <h2>{t("pages.pricing.support.heading")}</h2>
    <p>{t("pages.pricing.support.body")}</p>
    <p>{t("pages.pricing.support.hosting")}</p>
    <p>
      <a href="/app/contribute">{t("pages.pricing.support.link")}</a>
    </p>
  </section>
</section>

<style>
  .pricing-hero {
    position: relative;
    color: var(--hero-text);
    background-image: url("/app/assets/stockphotos/chicken-salad-1280.jpg");
    background-position: center;
    background-size: cover;
    padding: 140px 24px 60px;
  }

  @media (max-width: 800px) {
    .pricing-hero {
      padding: 50px 24px 50px;
    }
  }

  .pricing-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0.7) 0%, transparent 180px),
      var(--hero-overlay);
  }

  .pricing-hero-inner {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
  }

  .pricing-hero h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin: 0 0 12px;
    font-weight: 600;
  }

  .lead {
    font-size: 1.15rem;
    margin: 0;
    opacity: 0.95;
  }

  .pricing-content {
    max-width: 760px;
    margin: 0 auto;
    padding: 40px 24px 0;
  }

  .why {
    margin-bottom: 40px;
    line-height: 1.65;
  }

  .why .lede {
    font-size: 1.15rem;
    color: var(--text);
    margin: 0 0 16px;
  }

  .why p {
    color: var(--text-muted);
    margin: 0 0 12px;
  }

  .support {
    line-height: 1.65;
    margin-bottom: 40px;
  }

  .support h2 {
    font-size: 1.5rem;
    margin: 0 0 12px;
  }

  .support p {
    color: var(--text-muted);
    margin: 0 0 12px;
  }

  .support a {
    color: var(--btn-primary-bg);
  }
</style>
